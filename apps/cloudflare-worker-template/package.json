{
  "name": "cloudflare-worker-template",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy:staging:manual": "wrangler deploy --minify --env staging --env-file ../../.env.local",
    "deploy:staging": "wrangler deploy --minify --env staging",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply test_db --local",
    "db:migrate:staging": "wrangler d1 migrations apply test_db_staging --remote --env staging --env-file ../../.env.local",
    "deploy:staging:db:migrate": "wrangler d1 migrations apply test_db_staging --remote --env staging"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.3.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.4.0"
  }
}
